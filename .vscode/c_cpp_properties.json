{
    // ─────────────────────────────────────────────────────────────────────────
    //  FreeRTOS-OS-App  —  IntelliSense Configuration  (ROOT WORKSPACE)
    //
    //  Open the repo at FreeRTOS-OS-App/ in VS Code.
    //  Switch the active target via the bottom-right status bar (C/C++ config).
    // ─────────────────────────────────────────────────────────────────────────
    "configurations": [

        // ── STM32F411xE (primary target) ──────────────────────────────────────
        {
            "name": "STM32F411xE",
            "includePath": [
                // OS root (resolves bare includes like <def_std.h>)
                "${workspaceFolder}/FreeRTOS-OS",
                // OS public headers
                "${workspaceFolder}/FreeRTOS-OS/include",
                "${workspaceFolder}/FreeRTOS-OS/include/board",
                "${workspaceFolder}/FreeRTOS-OS/include/config",
                "${workspaceFolder}/FreeRTOS-OS/include/drivers",
                "${workspaceFolder}/FreeRTOS-OS/include/drivers/hal/stm32",
                "${workspaceFolder}/FreeRTOS-OS/include/ipc",
                "${workspaceFolder}/FreeRTOS-OS/include/irq",
                "${workspaceFolder}/FreeRTOS-OS/include/lib",
                "${workspaceFolder}/FreeRTOS-OS/include/mm",
                "${workspaceFolder}/FreeRTOS-OS/include/os",
                "${workspaceFolder}/FreeRTOS-OS/include/services",
                // Generated config (autoconf.h, FreeRTOSConfig.h, conf_os.h)
                "${workspaceFolder}/FreeRTOS-OS/config",
                // ARM CMSIS
                "${workspaceFolder}/FreeRTOS-OS/arch/arm/CMSIS_6",
                "${workspaceFolder}/FreeRTOS-OS/arch/arm/CMSIS_6/CMSIS/Core/Include",
                // STM32 device + HAL
                "${workspaceFolder}/FreeRTOS-OS/arch/devices",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/STM/STM32F4xx",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/STM/STM32F4xx/STM32F411",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/STM/stm32f4xx-hal-driver/Inc",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/device_conf",
                // FreeRTOS kernel
                "${workspaceFolder}/FreeRTOS-OS/kernel",
                "${workspaceFolder}/FreeRTOS-OS/kernel/FreeRTOS-Kernel/include",
                "${workspaceFolder}/FreeRTOS-OS/kernel/FreeRTOS-Kernel/portable/GCC/ARM_CM4F",
                // Library
                "${workspaceFolder}/FreeRTOS-OS/lib",
                // Application
                "${workspaceFolder}/app",
                "${workspaceFolder}/app/board",
                "${workspaceFolder}/app/os_conf_include"
            ],
            "defines": [
                // MCU target — selects CMSIS device header inside device.h
                "STM32F411xE",
                "USE_HAL_DRIVER",
                // Cortex-M4F
                "__ARM_ARCH_7EM__",
                "__FPU_PRESENT=1",
                "ARM_MATH_CM4",
                // Vendor variant — resolves #if CONFIG_DEVICE_VARIANT == MCU_VAR_STM
                "CONFIG_DEVICE_VARIANT=2",
                // HAL modules enabled (mirrors device_conf/stm32f4xx_hal_conf.h)
                "HAL_MODULE_ENABLED",
                "HAL_CORTEX_MODULE_ENABLED",
                "HAL_GPIO_MODULE_ENABLED",
                "HAL_EXTI_MODULE_ENABLED",
                "HAL_UART_MODULE_ENABLED",
                "HAL_I2C_MODULE_ENABLED",
                "HAL_SPI_MODULE_ENABLED",
                "HAL_TIM_MODULE_ENABLED",
                "HAL_RCC_MODULE_ENABLED",
                "HAL_DMA_MODULE_ENABLED",
                "HAL_FLASH_MODULE_ENABLED",
                "HAL_PWR_MODULE_ENABLED"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "gnu99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "gcc-arm",
            // forcedInclude injects autoconf.h before every TU — same as the Makefile
            "forcedInclude": [
                "${workspaceFolder}/FreeRTOS-OS/config/autoconf.h"
            ]
        },

        // ── STM32F401xE (secondary target) ───────────────────────────────────
        {
            "name": "STM32F401xE",
            "includePath": [
                "${workspaceFolder}/FreeRTOS-OS",
                "${workspaceFolder}/FreeRTOS-OS/include",
                "${workspaceFolder}/FreeRTOS-OS/include/board",
                "${workspaceFolder}/FreeRTOS-OS/include/config",
                "${workspaceFolder}/FreeRTOS-OS/include/drivers",
                "${workspaceFolder}/FreeRTOS-OS/include/drivers/hal/stm32",
                "${workspaceFolder}/FreeRTOS-OS/include/ipc",
                "${workspaceFolder}/FreeRTOS-OS/include/irq",
                "${workspaceFolder}/FreeRTOS-OS/include/lib",
                "${workspaceFolder}/FreeRTOS-OS/include/mm",
                "${workspaceFolder}/FreeRTOS-OS/include/os",
                "${workspaceFolder}/FreeRTOS-OS/include/services",
                "${workspaceFolder}/FreeRTOS-OS/config",
                "${workspaceFolder}/FreeRTOS-OS/arch/arm/CMSIS_6",
                "${workspaceFolder}/FreeRTOS-OS/arch/arm/CMSIS_6/CMSIS/Core/Include",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/STM/STM32F4xx",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/STM/STM32F4xx/STM32F401",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/STM/stm32f4xx-hal-driver/Inc",
                "${workspaceFolder}/FreeRTOS-OS/arch/devices/device_conf",
                "${workspaceFolder}/FreeRTOS-OS/kernel",
                "${workspaceFolder}/FreeRTOS-OS/kernel/FreeRTOS-Kernel/include",
                "${workspaceFolder}/FreeRTOS-OS/kernel/FreeRTOS-Kernel/portable/GCC/ARM_CM4F",
                "${workspaceFolder}/FreeRTOS-OS/lib",
                "${workspaceFolder}/app",
                "${workspaceFolder}/app/board",
                "${workspaceFolder}/app/os_conf_include"
            ],
            "defines": [
                "STM32F401xE",
                "USE_HAL_DRIVER",
                "__ARM_ARCH_7EM__",
                "__FPU_PRESENT=1",
                "ARM_MATH_CM4",
                "CONFIG_DEVICE_VARIANT=2",
                "HAL_MODULE_ENABLED",
                "HAL_CORTEX_MODULE_ENABLED",
                "HAL_GPIO_MODULE_ENABLED",
                "HAL_EXTI_MODULE_ENABLED",
                "HAL_UART_MODULE_ENABLED",
                "HAL_I2C_MODULE_ENABLED",
                "HAL_SPI_MODULE_ENABLED",
                "HAL_TIM_MODULE_ENABLED",
                "HAL_RCC_MODULE_ENABLED",
                "HAL_DMA_MODULE_ENABLED",
                "HAL_FLASH_MODULE_ENABLED",
                "HAL_PWR_MODULE_ENABLED"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "gnu99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "gcc-arm",
            "forcedInclude": [
                "${workspaceFolder}/FreeRTOS-OS/config/autoconf.h"
            ]
        }
    ],
    "version": 4
}
