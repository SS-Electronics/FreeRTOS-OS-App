<?xml version="1.0" encoding="UTF-8"?>
<!--
  Board description: STM32F411VET6 development board
  Vendor:  STM
  MCU:     STM32F411VET6  —  ARM Cortex-M4F, 100 MHz, 512 KB Flash, 128 KB RAM

  Usage
  ─────
  Edit this file to match your hardware wiring.
  Run the code generator to rebuild board_config.c and board_device_ids.h:

      python3 scripts/gen_board_config.py boards/stm32f411_devboard.xml

  Then rebuild the firmware:

      make all

  After generating, use the IDs from board_device_ids.h in application code:

      #include <board/board_device_ids.h>
      uart_mgmt_async_transmit(UART_DEBUG, data, len);
      board_uart_register_rx_cb(UART_DEBUG, my_rx_handler);

  Pin fields
  ──────────
    port   : GPIO port letter  (A, B, C, D, E)
    pin    : GPIO pin number   (0 – 15)
    af     : Alternate function number (see MCU datasheet AF table)
    speed  : low | medium | high | very_high
    pull   : none | pullup | pulldown

  I2C pin mode is always open-drain (AF_OD); UART/SPI always push-pull (AF_PP).

  GPIO mode values
  ────────────────
    output_pp   push-pull output
    output_od   open-drain output
    input       floating input
    it_rising   interrupt on rising edge
    it_falling  interrupt on falling edge
    it_both     interrupt on both edges

  active_state : high | low   (logical "active" level of the pin)
  initial_state: active | inactive   (state applied at board_init())
-->

<board name="STM32F411 Demo Devboard"
       vendor="STM"
       mcu="STM32F411VET6"
       description="STM32F411VET6 development board">

  <peripherals>

    <!-- ═══════════════════════════════════════════════════════════
         UART / USART
         ═══════════════════════════════════════════════════════════ -->

    <!--
      UART_DEBUG → USART1  PA9/TX  PA10/RX
      Primary debug / console serial port.
      AF7 = USART1 on STM32F411 pins PA9 / PA10.
    -->
    <uart id="UART_APP"
          dev_id="0"
          instance="USART1"
          baudrate="115200"
          word_len="8"
          stop_bits="1"
          parity="none"
          mode="tx_rx">
      <tx   port="A" pin="9"  af="7" speed="very_high" pull="none"/>
      <rx   port="A" pin="10" af="7" speed="very_high" pull="none"/>
      <irq  name="USART1_IRQn" priority="5"/>
    </uart>

    <!--
      UART_APP → USART2  PA2/TX  PA3/RX
      OS shell CLI port (role="shell").  Input from RX ring buffer via the
      RXNE ISR → irq_desc chain; output written to TX ring buffer and sent
      by the TXEIE interrupt-driven drain path.
      AF7 = USART2 on STM32F411 pins PA2 / PA3.
    -->
    <uart id="UART_DEBUG"
          dev_id="1"
          instance="USART2"
          baudrate="115200"
          word_len="8"
          stop_bits="1"
          parity="none"
          mode="tx_rx"
          role="shell">
      <tx   port="A" pin="2" af="7" speed="very_high" pull="none"/>
      <rx   port="A" pin="3" af="7" speed="very_high" pull="none"/>
      <irq  name="USART2_IRQn" priority="5"/>
    </uart>


    <!-- ═══════════════════════════════════════════════════════════
         I2C
         ═══════════════════════════════════════════════════════════ -->

    <!--
      I2C_SENSOR_BUS → I2C1  PB6/SCL  PB9/SDA
      Fast-mode 400 kHz bus for on-board sensors (LSM303DLHC, etc.).
      AF4 = I2C1 on STM32F411 Discovery: SCL=PB6, SDA=PB9 (UM1842 §6.11).
    -->
    <i2c id="I2C_SENSOR_BUS"
         dev_id="0"
         instance="I2C1"
         clock_hz="400000"
         addr_mode="7bit"
         dual_addr="disable">
      <scl   port="B" pin="6" af="4" speed="very_high" pull="none"/>
      <sda   port="B" pin="9" af="4" speed="very_high" pull="none"/>
      <irq_ev name="I2C1_EV_IRQn" priority="6"/>
      <irq_er name="I2C1_ER_IRQn" priority="6"/>
    </i2c>


    <!-- ═══════════════════════════════════════════════════════════
         SPI
         ═══════════════════════════════════════════════════════════ -->

    <!--
      SPI_FLASH_BUS → SPI1  PA5/SCK  PA6/MISO  PA7/MOSI  (software NSS)
      SPI master @ APB2/16 ≈ 6.25 MHz for flash / peripheral chips.
      AF5 = SPI1 on STM32F411 pins PA5 / PA6 / PA7.
    -->
    <spi id="SPI_FLASH_BUS"
         dev_id="0"
         instance="SPI1"
         mode="master"
         direction="2lines"
         data_size="8"
         clk_polarity="low"
         clk_phase="1edge"
         nss="soft"
         baud_prescaler="16"
         bit_order="msb">
      <sck  port="A" pin="5" af="5" speed="very_high" pull="none"/>
      <miso port="A" pin="6" af="5" speed="very_high" pull="none"/>
      <mosi port="A" pin="7" af="5" speed="very_high" pull="none"/>
      <!-- nss_pin omitted → software NSS -->
      <irq  name="SPI1_IRQn" priority="6"/>
    </spi>


    <!-- ═══════════════════════════════════════════════════════════
         GPIO
         ═══════════════════════════════════════════════════════════ -->

    <!-- PC13 — on-board LED (active-low on most STM32F411 boards) -->
    <gpio id="LED_BOARD"
          dev_id="0"
          port="C" pin="13"
          mode="output_pp"
          pull="none"
          speed="low"
          active_state="low"
          initial_state="inactive"/>

    <!-- PA0 — user push-button (active-high, pull-down) -->
    <gpio id="BTN_USER"
          dev_id="1"
          port="A" pin="0"
          mode="it_rising"
          pull="pulldown"
          speed="low"
          active_state="high"
          initial_state="inactive"/>

    <!-- PB0 — generic status indicator LED (active-high) -->
    <gpio id="LED_STATUS"
          dev_id="2"
          port="B" pin="0"
          mode="output_pp"
          pull="none"
          speed="low"
          active_state="high"
          initial_state="inactive"/>

  </peripherals>

</board>
